{
  "name": "blockend-cli",
  "version": "1.4.0",
  "description": "Intelligent, modular backend blocks right inside your terminal",
  "main": "./dist/index.js",
  "type": "module",
  "bin": {
    "blockend": "./dist/index.js"
  },
  "files": [
    "dist",
    "readme.md"
  ],
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "build": "tsup src/index.ts --format esm --dts --out-dir dist",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "cli",
    "backend",
    "express",
    "nextjs",
    "architecture"
  ],
  "author": "codewithnuh",
  "license": "ISC",
  "packageManager": "pnpm@10.33.2",
  "dependencies": {
    "@blockend/detector": "workspace:*",
    "@clack/prompts": "^1.5.1",
    "citty": "^0.2.2",
    "commander": "^15.0.0",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "tsup": "^8.5.1",
    "vitest": "^1.6.1"
  }
}
