{
  "name": "blockend-cli",
  "version": "1.5.0",
  "description": "CLI for installing production-ready backend blocks into Next.js, Express, Hono, NestJS, and other Node.js applications.",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "blockend": "./dist/index.js"
  },
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean --out-dir dist",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "pnpm build"
  },
  "keywords": [
    "blockend",
    "backend",
    "backend blocks",
    "backend boilerplate",
    "backend starter",
    "backend scaffolding",
    "backend generator",
    "backend cli",
    "nodejs",
    "nextjs",
    "express",
    "nestjs",
    "hono",
    "fastify",
    "authentication",
    "auth",
    "rbac",
    "payments",
    "stripe",
    "resend",
    "drizzle",
    "prisma",
    "postgresql",
    "typescript",
    "developer tools",
    "code generation",
    "scaffolding",
    "productivity",
    "cli"
  ],
  "homepage": "https://blockend.noorulhassan.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/codewithnuh/blockend.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/codewithnuh/blockend/issues"
  },
  "author": "codewithnuh",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.33.2",
  "dependencies": {
    "@clack/prompts": "^1.5.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "citty": "^0.2.2",
    "commander": "^15.0.0",
    "execa": "^9.6.1",
    "picocolors": "^1.1.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "tsup": "^8.5.1",
    "vitest": "^1.6.1"
  }
}
