{
  "$schema": "./registry-schema.json",
  "version": "1.0.0",
  "blocks": {
    "rate-limit": {
      "name": "Rate Limiter",
      "description": "IP-based rate limiting middleware with pluggable storage strategies",
      "environments": {
        "express": {
          "core": "blocks/rate-limiter/express/base.ts",
          "devDependencies": ["vitest", "supertest", "@types/supertest", "@types/express"],
          "variants": {
            "memory": {
              "dependencies": [],
              "files": [
                {
                  "source": "blocks/rate-limiter/express/store-memory.ts",
                  "target": "store-memory.ts"
                },
                {
                  "source": "blocks/rate-limiter/express/tests/store-memory.test.ts",
                  "target": "tests/store-memory.test.ts"
                },
                {
                  "source": "blocks/rate-limiter/express/tests/base.test.ts",
                  "target": "tests/base.test.ts"
                }
              ]
            },
            "redis": {
              "dependencies": ["ioredis"],
              "files": [
                {
                  "source": "blocks/rate-limiter/express/store-redis.ts",
                  "target": "store-redis.ts"
                },
                {
                  "source": "blocks/rate-limiter/express/tests/store-redist.test.ts",
                  "target": "tests/store-redis.test.ts"
                },
                {
                  "source": "blocks/rate-limiter/express/tests/base.test.ts",
                  "target": "tests/base.test.ts"
                }
              ]
            }
          }
        }
      }
    },
    "error-handler": {
      "name": "Global Error Handler",
      "description": "Centralized Express error handling...",
      "environments": {
        "express": {
          "variants": {
            "default": {
              "dependencies": ["zod"],
              "devDependencies": ["vitest", "supertest", "@types/supertest", "@types/express"],
              "files": [
                { "source": "blocks/error-handler/express/app-error.ts", "target": "app-error.ts" },
                {
                  "source": "blocks/error-handler/express/async-handler.ts",
                  "target": "async-handler.ts"
                },
                { "source": "blocks/error-handler/express/errors.ts", "target": "errors.ts" },
                {
                  "source": "blocks/error-handler/express/global-error-handler.ts",
                  "target": "global-error-handler.ts"
                },
                {
                  "source": "blocks/error-handler/express/http-status.ts",
                  "target": "http-status.ts"
                },
                { "source": "blocks/error-handler/express/index.ts", "target": "index.ts" },
                {
                  "source": "blocks/error-handler/express/throw-error.ts",
                  "target": "throw-error.ts"
                }
              ]
            }
          }
        }
      }
    },
    "logger": {
      "name": "Structured Context Logger",
      "description": "Framework-agnostic context logging engine using AsyncLocalStorage with production redactions and automatic request ID tracing.",
      "baseFiles": [
        {
          "source": "blocks/logger/core.ts",
          "target": "core.ts"
        },
        {
          "source": "blocks/logger/tests/core.test.ts",
          "target": "tests/core.test.ts"
        }
      ],
      "adapters": {
        "express": {
          "dependencies": ["pino"],
          "devDependencies": [
            "pino-pretty",
            "vitest",
            "supertest",
            "@types/supertest",
            "@types/express"
          ],
          "variants": {
            "default": {
              "files": [
                {
                  "source": "blocks/logger/adapters/express.ts",
                  "target": "express-adapter.ts"
                },
                {
                  "source": "blocks/logger/tests/express.test.ts",
                  "target": "tests/express-adapter.test.ts"
                }
              ]
            }
          }
        },
        "fastify": {
          "dependencies": ["pino"],
          "devDependencies": [
            "pino-pretty",
            "vitest",
            "supertest",
            "@types/supertest",
            "@types/node"
          ],
          "variants": {
            "default": {
              "files": [
                {
                  "source": "blocks/logger/adapters/fastify.ts",
                  "target": "adapters/fastify.ts"
                },
                {
                  "source": "blocks/logger/tests/fastify.test.ts",
                  "target": "tests/fastify-adapter.test.ts"
                }
              ]
            }
          }
        },
        "hono": {
          "dependencies": ["pino"],
          "devDependencies": ["pino-pretty", "vitest", "@types/node"],
          "variants": {
            "default": {
              "files": [
                {
                  "source": "blocks/logger/adapters/hono.ts",
                  "target": "adapters/hono.ts"
                },
                {
                  "source": "blocks/logger/tests/hono.test.ts",
                  "target": "tests/hono-adapter.test.ts"
                }
              ]
            }
          }
        }
      }
    },
    "request-validator": {
      "name": "Request Validator",
      "description": "Framework-agnostic request validation powered by Zod. Validate request bodies, query parameters, and route params through lightweight adapters while keeping validation logic independent of the web framework.",
      "baseFiles": [
        {
          "source": "blocks/request-validator/core.ts",
          "target": "core.ts"
        },
        {
          "source": "blocks/request-validator/contract.ts",
          "target": "contract.ts"
        },
        {
          "source": "blocks/request-validator/tests/core.test.ts",
          "target": "tests/core.test.ts"
        }
      ],
      "adapters": {
        "express": {
          "dependencies": ["zod", "express"],
          "devDependencies": ["vitest", "supertest", "@types/supertest", "@types/express"],
          "variants": {
            "default": {
              "files": [
                {
                  "source": "blocks/request-validator/adapters/express.ts",
                  "target": "adapters/express.ts"
                },
                {
                  "source": "blocks/request-validator/tests/express.test.ts",
                  "target": "tests/express-adapter.test.ts"
                }
              ]
            }
          }
        }
      }
    },
    "response-formatter": {
      "name": "Response Formatter",
      "description": "Framework-agnostic API response formatting with lightweight adapters. Create consistent success, error, and paginated responses while keeping formatting logic independent of the web framework.",
      "baseFiles": [
        {
          "source": "blocks/response-formatter/core.ts",
          "target": "core.ts"
        },
        {
          "source": "blocks/response-formatter/contract.ts",
          "target": "contract.ts"
        },
        {
          "source": "blocks/response-formatter/tests/core.test.ts",
          "target": "tests/core.test.ts"
        }
      ],
      "adapters": {
        "express": {
          "dependencies": ["express"],
          "devDependencies": ["vitest", "supertest", "@types/supertest", "@types/express"],
          "variants": {
            "default": {
              "files": [
                {
                  "source": "blocks/response-formatter/adapters/express.ts",
                  "target": "adapters/express.ts"
                },
                {
                  "source": "blocks/response-formatter/tests/express.test.ts",
                  "target": "tests/express-adapter.test.ts"
                }
              ]
            }
          }
        }
      }
    },
    "env-config": {
      "name": "Environment Configuration",
      "description": "Type-safe environment variable validation using Zod. Validate configuration once at startup, fail fast on invalid values, and access a fully typed environment object throughout your application.",
      "baseFiles": [
        {
          "source": "blocks/env-config/index.ts",
          "target": "index.ts"
        }
      ],
      "frameworks": ["*"],
      "adapters": {
        "*": {
          "variants": {
            "default": {
              "files": ["blocks/env-config/index.ts"]
            }
          }
        }
      },

      "dependencies": ["zod", "dotenv"]
    }
  }
}
