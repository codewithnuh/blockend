{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "BlockendRegistryManifest",
  "type": "object",
  "required": ["version", "blocks"],
  "properties": {
    "version": {
      "type": "string",
      "description": "The semantic version of the registry schema layout."
    },
    "blocks": {
      "type": "object",
      "description": "Dictionary lookup table of all available ingestible component blocks.",
      "additionalProperties": {
        "type": "object",
        "required": ["name", "description"],
        "properties": {
          "name": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "frameworks": {
            "type": "array",
            "description": "Explicit framework support list.",
            "items": {
              "type": "string",
              "enum": ["express", "fastify", "hono", "next", "*"]
            },
            "uniqueItems": true
          },
          "dependencies": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "devDependencies": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "baseFiles": {
            "type": "array",
            "items": {
              "$ref": "#/definitions/assetMapping"
            }
          },
          "adapters": {
            "type": "object",
            "description": "Framework adapter mappings.",
            "propertyNames": {
              "enum": ["express", "fastify", "hono", "next", "*"]
            },
            "additionalProperties": {
              "$ref": "#/definitions/frameworkMapping"
            }
          },
          "environments": {
            "type": "object",
            "description": "Legacy framework mappings.",
            "propertyNames": {
              "enum": ["express", "fastify", "hono", "next", "*"]
            },
            "additionalProperties": {
              "$ref": "#/definitions/frameworkMapping"
            }
          }
        },
        "additionalProperties": false
      }
    }
  },
  "definitions": {
    "assetMapping": {
      "type": "object",
      "required": ["source", "target"],
      "properties": {
        "source": {
          "type": "string",
          "description": "Remote template path."
        },
        "target": {
          "type": "string",
          "description": "Destination path."
        }
      },
      "additionalProperties": false
    },
    "frameworkMapping": {
      "type": "object",
      "required": ["variants"],
      "properties": {
        "core": {
          "type": "string",
          "description": "Optional fallback template."
        },
        "dependencies": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "devDependencies": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "variants": {
          "type": "object",
          "description": "Storage layout strategies.",
          "additionalProperties": {
            "type": "object",
            "required": ["files"],
            "properties": {
              "dependencies": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "devDependencies": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "files": {
                "type": "array",
                "items": {
                  "oneOf": [
                    {
                      "type": "string"
                    },
                    {
                      "$ref": "#/definitions/assetMapping"
                    }
                  ]
                }
              }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    }
  }
}
